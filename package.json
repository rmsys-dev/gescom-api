{
  "name": "gescom_wpp_service",
  "version": "1.0.0",
  "description": "Whatsapp Service API for Gescom Sys",
  "license": "ISC",
  "author": "LeomirDias",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec tsx src/server.ts",
    "dev:poll": "nodemon --legacy-watch --watch src --ext ts --exec tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "test:integration": "node --import tsx --test \"src/**/*.integration.test.ts\"",
    "load:burst": "node --import tsx scripts/load/burst-mensagens-texto.js",
    "load:burst:documento": "node --import tsx scripts/load/burst-mensagens-documento.js",
    "validate:technical": "npm run test:integration && npm run load:burst && npm run load:burst:documento",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:check-migrations": "tsx scripts/db/check-migrations-status.ts",
    "db:baseline-migrations": "tsx scripts/db/baseline-drizzle-migrations.ts",
    "db:check-pending-migrations": "tsx scripts/db/check-pending-migration-files.ts",
    "db:compare-prod-schema": "tsx scripts/db/compare-prod-schema.ts",
    "db:apply:pending-prod": "tsx scripts/db/apply-pending-prod-migrations.ts",
    "db:apply:0009-prod": "tsx scripts/db/apply-0009-prod-migration.ts",
    "db:apply:members-profile-tables": "tsx scripts/db/apply-members-profile-tables.ts",
    "db:apply:enterprises-members-limits": "tsx scripts/db/apply-enterprises-members-limits.ts",
    "db:apply:0017-prod": "tsx scripts/db/apply-0017-product-taxation-pis-cofins.ts",
    "db:verify:members-profile": "tsx scripts/db/verify-members-profile-schema.ts",
    "db:verify:enterprises-members": "tsx scripts/db/verify-enterprises-members-schema.ts",
    "db:backup:snapshot": "tsx scripts/db/capture-pre-migration-snapshot.ts",
    "db:push": "drizzle-kit push",
    "db:prepare:sequences-push": "tsx scripts/db/prepare-enterprises-sequences-push.ts",
    "db:bootstrap:sequences": "tsx scripts/db/bootstrap-enterprises-sequences.ts",
    "db:register:migration-0010": "tsx scripts/db/register-migration-0010.ts",
    "db:reset-test": "tsx scripts/db/reset-test-database.ts",
    "seed:bootstrap": "tsx scripts/seed/bootstrap.ts",
    "seed:enterprise-switch-test": "tsx scripts/seed/enterprise-switch-test.ts",
    "seed:fictitious-users": "tsx scripts/seed/fictitious-users.ts",
    "seed:fictitious-addresses": "tsx scripts/seed/fictitious-addresses.ts",
    "seed:test-data": "tsx scripts/seed/test-data.ts",
    "postman:generate": "tsx scripts/postman/generate-collections.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.1",
    "axios": "^1.15.1",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.75.2",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "postgres": "^3.4.9",
    "resend": "^6.12.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "autocannon": "^8.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.1",
    "md-to-pdf": "^5.2.4",
    "eslint-config-prettier": "^10.1.8",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  }
}
