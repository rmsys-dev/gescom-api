# Configuracao geral
PORT="PORT - Porta do servidor"

# Config de conexão com Supabase
DATABASE_URL="DATABASE_URL - URL do PostgreSQL para a aplicação"
DRIZZLE_DATABASE_URL="DRIZZLE_DATABASE_URL - URL do PostgreSQL para o Drizzle ORM"

# Config de chave secreta JWT
JWT_SECRET="JWT_SECRET - Segredo para assinatura do token de acesso"
JWT_ACCESS_EXPIRES_IN="JWT_ACCESS_EXPIRES_IN - Tempo de expiração do token de acesso"
JWT_ISSUER="JWT_ISSUER - Emissor esperado dos tokens JWT"
JWT_AUDIENCE="JWT_AUDIENCE - Audiência esperada dos tokens JWT"
JWT_REFRESH_SECRET="JWT_REFRESH_SECRET - Segredo para assinatura do token de refresh"
JWT_REFRESH_EXPIRES_IN="JWT_REFRESH_EXPIRES_IN - Tempo de expiração do token de refresh"

# Config de seguranca de autenticacao
BCRYPT_ROUNDS="BCRYPT_ROUNDS - Número de rounds para a hash de senha"
AUTH_MAX_FAILED_ATTEMPTS="AUTH_MAX_FAILED_ATTEMPTS - Número máximo de tentativas de login falhas"
AUTH_LOCK_BASE_MINUTES="AUTH_LOCK_BASE_MINUTES - Tempo base em minutos para bloqueio de conta"
AUTH_RATE_LIMIT_WINDOW_MS="AUTH_RATE_LIMIT_WINDOW_MS - Tempo em milissegundos para limite de tentativas de login"
AUTH_RATE_LIMIT_MAX="AUTH_RATE_LIMIT_MAX - Número máximo de tentativas de login"
API_RATE_LIMIT_WINDOW_MS="API_RATE_LIMIT_WINDOW_MS - Janela global de rate limit da API"
API_RATE_LIMIT_MAX="API_RATE_LIMIT_MAX - Número máximo de requisições por janela para a API"

# Config de CORS
CORS_ORIGINS="CORS_ORIGINS - Lista separada por vírgulas de origens permitidas"

# RMSys / maintainer — rotas em /v1/maintainer/enterprises (cabecalho X-Maintainer-Api-Key)
MAINTAINER_API_KEY="MAINTAINER_API_KEY - Segredo com pelo menos 32 caracteres"

# Config de Resend (e-mail)
RESEND_API_KEY="API_KEY_RESEND - Chave da API Resend"
MAIL_FROM="EMAIL_FROM - E-mail remetente"
MAIL_FROM_NAME="MAIL_FROM_NAME - Nome do remetente"
EMAIL_SEND_RATE_LIMIT_WINDOW_MS="EMAIL_SEND_RATE_LIMIT_WINDOW_MS - Janela em milissegundos para limitar envios de e-mail"
EMAIL_SEND_RATE_LIMIT_MAX="EMAIL_SEND_RATE_LIMIT_MAX - Quantidade maxima de e-mails permitida por janela"

# Config de limite de tentativas de primeiro acesso
FIRST_ACCESS_RATE_LIMIT_WINDOW_MS="FIRST_ACCESS_RATE_LIMIT_WINDOW_MS - Tempo em milissegundos para limite de tentativas de primeiro acesso"
FIRST_ACCESS_RATE_LIMIT_MAX="FIRST_ACCESS_RATE_LIMIT_MAX - Número máximo de tentativas de primeiro acesso"
FIRST_ACCESS_EMAIL_LIMIT_WINDOW_MINUTES="FIRST_ACCESS_EMAIL_LIMIT_WINDOW_MINUTES - Tempo em minutos para limite de tentativas de email de primeiro acesso"
FIRST_ACCESS_EMAIL_LIMIT_MAX="FIRST_ACCESS_EMAIL_LIMIT_MAX - Número máximo de tentativas de email de primeiro acesso"
INVITATION_CODE_TTL_MINUTES="INVITATION_CODE_TTL_MINUTES - Tempo em minutos para expiração do código de convite"
INVITATION_MAX_ATTEMPTS="INVITATION_MAX_ATTEMPTS - Número máximo de tentativas de convite"
INVITATION_CODE_LENGTH="INVITATION_CODE_LENGTH - Comprimento do código de convite"

# Config de redefinicao de senha
PASSWORD_RESET_RATE_LIMIT_WINDOW_MS="PASSWORD_RESET_RATE_LIMIT_WINDOW_MS - Tempo em milissegundos para limite de tentativas de redefinicao de senha"
PASSWORD_RESET_RATE_LIMIT_MAX="PASSWORD_RESET_RATE_LIMIT_MAX - Número máximo de tentativas de redefinicao de senha"
PASSWORD_RESET_EMAIL_LIMIT_WINDOW_MINUTES="PASSWORD_RESET_EMAIL_LIMIT_WINDOW_MINUTES - Tempo em minutos para limite de envio de email de redefinicao de senha"
PASSWORD_RESET_EMAIL_LIMIT_MAX="PASSWORD_RESET_EMAIL_LIMIT_MAX - Número máximo de envios de email de redefinicao de senha"
PASSWORD_RESET_CODE_TTL_MINUTES="PASSWORD_RESET_CODE_TTL_MINUTES - Tempo em minutos para expiração do código de redefinicao de senha"
PASSWORD_RESET_MAX_ATTEMPTS="PASSWORD_RESET_MAX_ATTEMPTS - Número máximo de tentativas do código de redefinicao de senha"
PASSWORD_RESET_CODE_LENGTH="PASSWORD_RESET_CODE_LENGTH - Comprimento do código de redefinicao de senha"
