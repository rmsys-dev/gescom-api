{
  "name": "gescom_wpp_service",
  "version": "1.0.0",
  "description": "Whatsapp Service API for Gescom Sys",
  "license": "ISC",
  "author": "LeomirDias",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec tsx src/server.ts",
    "dev:poll": "nodemon --legacy-watch --watch src --ext ts --exec tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "test:integration": "node --import tsx --test \"src/**/*.integration.test.ts\"",
    "load:burst": "node --import tsx scripts/load/burst-mensagens-texto.js",
    "load:burst:documento": "node --import tsx scripts/load/burst-mensagens-documento.js",
    "validate:technical": "npm run test:integration && npm run load:burst && npm run load:burst:documento",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:migrate:pending": "tsx scripts/migrate-pending.ts",
    "seed:bootstrap": "tsx scripts/seed-bootstrap.ts",
    "seed:enterprise-switch-test": "tsx scripts/seed-enterprise-switch-test.ts",
    "seed:fictitious-users": "tsx scripts/seed-fictitious-users.ts",
    "seed:fictitious-addresses": "tsx scripts/seed-fictitious-addresses.ts",
    "seed:test-data": "tsx scripts/seed-test-data.ts",
    "postman:auth": "npx newman run docs/postman-collections/auth-collection/postman-auth-collection.json -e docs/postman-collections/postman-global-environment.json",
    "postman:login": "npx newman run docs/postman-collections/auth-collection/postman-auth-collection.json -e docs/postman-collections/postman-global-environment.json --folder \"Auth - Login (EMAIL)\"",
    "postman:enterprises": "npx newman run docs/postman-collections/auth-collection/postman-enterprises-collection.json -e docs/postman-collections/postman-global-environment.json",
    "postman:departments": "npx newman run docs/postman-collections/auth-collection/postman-departments-collection.json -e docs/postman-collections/postman-global-environment.json",
    "postman:users": "npx newman run docs/postman-collections/auth-collection/postman-users-collection.json -e docs/postman-collections/postman-global-environment.json",
    "postman:users:onboarding": "npx newman run docs/postman-collections/auth-collection/postman-users-onboarding-collection.json -e docs/postman-collections/postman-global-environment.json",
    "postman:memberships": "npx newman run docs/postman-collections/auth-collection/postman-memberships-collection.json -e docs/postman-collections/postman-global-environment.json",
    "postman:maintainer": "npx newman run docs/postman-collections/maintainer-collection/postman-maintainer-collection.json -e docs/postman-collections/postman-global-environment.json",
    "postman:addresses": "npx newman run docs/postman-collections/auth-collection/postman-addresses-collection.json -e docs/postman-collections/postman-global-environment.json",
    "postman:addresses:maintainer": "npx newman run docs/postman-collections/maintainer-collection/postman-addresses-collection.json -e docs/postman-collections/postman-global-environment.json"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.1",
    "axios": "^1.15.1",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.75.2",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "postgres": "^3.4.9",
    "resend": "^6.12.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "autocannon": "^8.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.1",
    "md-to-pdf": "^5.2.4",
    "eslint-config-prettier": "^10.1.8",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  }
}
